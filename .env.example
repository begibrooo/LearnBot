# ── Bot ───────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
CONTENT_CHANNEL_ID=-1001234567890
REQUIRED_CHANNELS=@yourchannel

# ── Settings ─────────────────────────────────────────
INVITES_PER_FREE_PASS=5
MAX_WRONG_ATTEMPTS=3
LOCKOUT_MINUTES=15

# ── AI Chat (Groq — free at console.groq.com) ────────
AI_PROVIDER=groq
AI_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
AI_MODEL=llama-3.3-70b-versatile
AI_DAILY_LIMIT=50
AI_SYSTEM_PROMPT=You are a helpful learning assistant for this educational platform.

# ── Web App / Games ───────────────────────────────────
WEBAPP_URL=https://your-webapp.netlify.app
WEBAPP_PORT=8080

# ── Database persistence (Railway volume) ────────────
DATA_DIR=/data
